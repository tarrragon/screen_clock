{
  "version": "1.0.0",
  "description": "Hook configuration registry - defines all hooks that should be registered in settings.json",
  "last_updated": "2025-01-23",
  "schema": {
    "description": "hooks 欄位為以事件類型為 key 的 dict 結構（object），每個 key 是 Claude Code 支援的 Hook 事件類型",
    "hooks": {
      "type": "object",
      "key": {
        "type": "string",
        "description": "Hook 事件類型",
        "valid_values": ["PreToolUse", "PostToolUse", "SessionStart", "UserPromptSubmit", "Stop"]
      },
      "value": {
        "type": "array",
        "description": "HookGroup 陣列，每個 HookGroup 對應一個工具匹配規則與命令清單",
        "items": {
          "type": "object",
          "properties": {
            "matcher": {
              "type": "string | null",
              "description": "工具名稱（如 'Bash', 'Edit', 'Write'），null 表示匹配所有工具"
            },
            "commands": {
              "type": "array of string",
              "description": "當 Hook 觸發時依序執行的命令路徑清單"
            }
          }
        }
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "commands": [
          ".claude/hooks/test-timeout-pre.py",
          ".claude/hooks/version-release-guard-hook.py"
        ]
      },
      {
        "matcher": "mcp__dart__run_tests",
        "commands": [
          ".claude/hooks/mcp-run-tests-validator.py",
          ".claude/hooks/test-timeout-pre.py"
        ]
      },
      {
        "matcher": "Edit",
        "commands": [
          ".claude/hooks/branch-verify-hook.py",
          ".claude/skills/strategic-compact/suggest-compact.sh"
        ]
      },
      {
        "matcher": "Write",
        "commands": [
          ".claude/hooks/branch-verify-hook.py",
          ".claude/skills/strategic-compact/suggest-compact.sh"
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": null,
        "commands": [
          ".claude/hooks/hook-completeness-check.py",
          ".claude/hooks/branch-status-reminder.py",
          ".claude/hooks/output-style-check.py"
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "commands": [
          ".claude/hooks/test-timeout-post.py",
          ".claude/hooks/pre-fix-evaluation-hook.py"
        ]
      },
      {
        "matcher": "mcp__dart__run_tests",
        "commands": [
          ".claude/hooks/test-timeout-post.py",
          ".claude/hooks/pre-fix-evaluation-hook.py"
        ]
      },
      {
        "matcher": "Edit",
        "commands": [
          ".claude/hooks/style-guardian-hook.py",
          ".claude/hooks/worklog-format-check.py"
        ]
      },
      {
        "matcher": "Write",
        "commands": [
          ".claude/hooks/style-guardian-hook.py",
          ".claude/hooks/worklog-format-check.py"
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": null,
        "commands": [
          ".claude/hooks/command-entrance-gate-hook.py",
          ".claude/hooks/creation-acceptance-gate-hook.py",
          ".claude/hooks/prompt-submit-hook.py",
          ".claude/hooks/language-guard-hook.py",
          ".claude/hooks/handoff-prompt-reminder-hook.py",
          ".claude/hooks/parallel-suggestion-hook.py",
          ".claude/hooks/process-skip-guard-hook.py"
        ]
      }
    ],
    "Stop": [
      {
        "matcher": null,
        "commands": [
          "$CLAUDE_PROJECT_DIR/.claude/skills/continuous-learning/evaluate-session.py"
        ]
      }
    ]
  }
}
