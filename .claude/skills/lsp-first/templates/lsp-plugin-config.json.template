{
  "// 說明": "LSP 插件配置範本",
  "// 使用方式": "複製此範本到 .claude/plugins/<plugin-name>/.lsp.json",

  "{LANGUAGE_ID}": {
    "command": "{LSP_SERVER_COMMAND}",
    "args": ["{LSP_SERVER_ARGS}"],
    "extensionToLanguage": {
      ".{FILE_EXTENSION}": "{LANGUAGE_ID}"
    }
  }
}

