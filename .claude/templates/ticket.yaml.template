# Atomic Ticket 定義範本
# 版本: v1.0.0
# 使用方式: /ticket create 會自動使用此範本建立 Ticket YAML

ticket:
  # 唯一識別碼 - 格式: {Version}-W{Wave}-{Seq}
  id: "{VERSION}-W{WAVE}-{SEQ}"

  # 版本資訊
  version: "{VERSION}"
  wave: {WAVE}

  # 單一職責定義（核心）
  action: "{ACTION}"      # 動詞：實作、修復、新增、重構、移除
  target: "{TARGET}"      # 單一目標：具體的方法、類別、功能

  # 執行資訊
  agent: "{AGENT}"        # 執行代理人

  # 5W1H 設計資訊（唯一事實源）
  who: "{AGENT}"
  what: "{ACTION} {TARGET}"
  when: "{TRIGGER_CONDITION}"
  where: "{FILE_PATH}"
  why: "{REASON}"
  how: "{IMPLEMENTATION_STRATEGY}"

  # 驗收條件（都應指向同一目標）
  acceptance:
    - "{CRITERIA_1}"
    - "{CRITERIA_2}"
    # 驗收條件應該：
    # 1. 都指向 {TARGET}
    # 2. 可客觀驗證
    # 3. 不超過 3-5 個

  # 相關檔案
  files:
    - "{SOURCE_FILE}"
    - "{TEST_FILE}"

  # 依賴關係
  dependencies: []
  # 格式: ["{VERSION}-W{WAVE}-{SEQ}", ...]
  # W1 的 Ticket 通常沒有依賴
  # W2+ 的 Ticket 依賴前一 Wave 的特定 Ticket

  # Ticket 關聯追蹤（新增）
  source_ticket: null          # 觸發此 Ticket 的來源 Ticket ID
  spawned_tickets: []          # 此 Ticket 衍生的後續 Ticket IDs
  dispatch_reason: ""          # 派發原因/交接理由
  # 關聯追蹤用於：
  # - 開發 (IMP) → 測試 (TST) → 調整 (ADJ) 的鏈式追蹤
  # - 記錄 Ticket 之間的因果關係和交接理由
  # - 支援「/ticket track chain」命令查詢完整關聯鏈

  # 參考文件
  references: []
  # 格式: ["path/to/doc.md", "path/to/spec.md"]

  # 決策樹決策過程（記錄此 Ticket 如何通過決策樹得出）
  decision_tree_path:
    entry_point: "{ENTRY_LAYER}"
    # 進入決策樹的層級（第零層~第七層）
    # 例：第一層：訊息類型判斷
    #    第三層：命令處理流程
    #    第五層：TDD 階段判斷

    decision_nodes: []
    # 經過的決策節點清單，記錄決策過程
    # 格式範例：
    # - layer: "1"
    #   question: "訊息類型是什麼？"
    #   answer: "開發/修改命令"
    #   next_action: "進入第三層：命令處理流程"
    # - layer: "3"
    #   question: "涉及安全相關嗎？"
    #   answer: "否"
    #   next_action: "進入第四層：Ticket 執行流程"

    final_decision: "{FINAL_AGENT_OR_ACTION}"
    # 最終決策結果
    # 例：派發給 parsley-flutter-developer
    #    執行 /ticket create
    #    派發給 system-analyst（需 SA 前置審查）

    rationale: "{DECISION_RATIONALE}"
    # 決策理由（簡述為何做出此決策）
    # 例：「新功能需求，涉及多個架構層，需要 SA 審查確保系統一致性」
    #    「測試失敗，需要派發 incident-responder 進行分析」

# 單一職責檢查（建立時自動驗證）
# [ ] 語義檢查：能用「{ACTION} {TARGET}」表達
# [ ] 修改原因：只有一個原因會導致修改
# [ ] 驗收一致性：所有驗收條件指向 {TARGET}
# [ ] 依賴獨立性：拆分後不會產生循環依賴
